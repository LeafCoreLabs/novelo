# ──────────────────────────────────────────────────────────────
# Novelo environment configuration
# Copy to `.env` for local development: cp .env.example .env
# ──────────────────────────────────────────────────────────────

NODE_ENV=development

# ── App ──
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Novelo
NEXT_PUBLIC_GITHUB_URL=https://github.com/LeafCoreLabs/novelo

# ── Supabase ──
# Dashboard → Settings → Database (password) + Settings → API (keys)
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_DB_PASSWORD=your-database-password

# After setting SUPABASE_DB_PASSWORD, run: npm run env:supabase
DATABASE_URL=postgresql://postgres.your-project-ref:PASSWORD@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres.your-project-ref:PASSWORD@aws-0-ap-south-1.pooler.supabase.com:5432/postgres

# Local Docker Postgres (optional fallback)
# DATABASE_URL=postgresql://nobelo:nobelo_secret@localhost:5433/nobelo?schema=public
# DIRECT_URL=postgresql://nobelo:nobelo_secret@localhost:5433/nobelo?schema=public

# ── Auth ──
AUTH_PROVIDER=jwt
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# ── Redis ──
REDIS_URL=redis://localhost:6379
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ── Storage ──
# supabase (cloud) | minio (local Docker)
STORAGE_PROVIDER=supabase
S3_BUCKET=novelo-media
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=nobelo
S3_SECRET_KEY=nobelo_secret

# ── Email ──
SMTP_HOST=localhost
SMTP_PORT=1025
EMAIL_FROM=Novelo <hello@novelo.local>
